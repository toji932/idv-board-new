* {
  box-sizing: border-box;
}

html,
body,
#root {
  margin: 0;
  width: 100%;
  height: 100%;
  font-family: "Yu Gothic", "Yu Gothic UI", "Meiryo", sans-serif;
  background: #eef2f7;
  color: #111827;
}

button,
input,
select {
  font: inherit;
}

.app {
  display: flex;
  height: 100vh;
  overflow: hidden;
}

.sidebar {
  width: 360px;
  min-width: 360px;
  max-width: 360px;
  padding: 12px;
  overflow-y: auto;
  background: #ffffff;
  border-right: 1px solid #d1d5db;
}

.sidebar h1 {
  margin: 0 0 12px;
  font-size: 22px;
}

.panel {
  margin-bottom: 12px;
  padding: 12px;
  border: 1px solid #d1d5db;
  border-radius: 12px;
  background: #fafafa;
}

.panel h2 {
  margin: 0 0 10px;
  font-size: 15px;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 5px;
  margin-bottom: 10px;
}

.field-full {
  grid-column: 1 / -1;
}

.field label {
  font-size: 12px;
  font-weight: 700;
  color: #374151;
}

.field input,
.field select {
  width: 100%;
  min-width: 0;
  padding: 7px 9px;
  border: 1px solid #cbd5e1;
  border-radius: 8px;
  background: #fff;
}

.grid2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}

.inline-row {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 8px;
}

.button-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

button {
  padding: 7px 10px;
  border: 1px solid #cbd5e1;
  border-radius: 8px;
  background: #ffffff;
  cursor: pointer;
}

button:hover {
  background: #f3f4f6;
}

.active-btn {
  background: #dbeafe;
  border-color: #60a5fa;
}

.hint {
  font-size: 12px;
  color: #6b7280;
}

.rows-box {
  max-height: 220px;
  overflow-y: auto;
  border: 1px solid #d1d5db;
  border-radius: 8px;
  background: #fff;
}

.row-item {
  width: 100%;
  text-align: left;
  border: 0;
  border-bottom: 1px solid #e5e7eb;
  border-radius: 0;
  background: #fff;
  padding: 10px;
}

.row-item:hover {
  background: #f9fafb;
}

.row-sub {
  margin-top: 4px;
  font-size: 12px;
  color: #6b7280;
}

.color-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.color-chip {
  width: 28px;
  height: 28px;
  padding: 0;
  border-radius: 999px;
  border: 2px solid transparent;
}

.selected-color {
  border-color: #111827;
}

.cipher-tool-grid {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.cipher-tool-row {
  display: grid;
  grid-template-columns: 22px 1fr auto;
  gap: 8px;
  align-items: center;
}

.cipher-tool-row input {
  min-width: 0;
  padding: 7px 9px;
  border: 1px solid #cbd5e1;
  border-radius: 8px;
  background: #fff;
}

.cipher-tool-label {
  font-size: 12px;
  font-weight: 700;
  text-align: center;
}

.main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  padding: 12px;
  gap: 10px;
  overflow: hidden;
}

.meta-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 6px 12px;
  padding: 10px 12px;
  border: 1px solid #d1d5db;
  border-radius: 10px;
  background: #fff;
  font-size: 13px;
  font-weight: 700;
  flex: 0 0 auto;
}

.board-wrap {
  flex: 1;
  min-height: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.board {
  position: relative;
  width: min(100%, 125vh);
  aspect-ratio: 16 / 10;
  border: 2px solid #cbd5e1;
  border-radius: 12px;
  background-position: center;
  background-repeat: no-repeat;
  background-color: #e5e7eb;
  overflow: hidden;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  touch-action: none;
}

.board-leo {
  background-size: contain;
}

.board-park {
  background-size: cover;
}

.annotation-layer {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: auto;
  z-index: 2;
}

.cipher-board-layer {
  position: absolute;
  left: 12px;
  top: 12px;
  z-index: 3;
  display: grid;
  grid-template-columns: repeat(4, auto);
  gap: 8px;
  max-width: calc(100% - 24px);
}

.cipher-map-box {
  min-width: 54px;
  padding: 6px 8px;
  border-radius: 10px;
  background: rgba(255, 255, 255, 0.94);
  border: 1px solid #cbd5e1;
  display: flex;
  align-items: center;
  gap: 6px;
  font-weight: 700;
  font-size: 13px;
}

.cipher-map-id {
  width: 18px;
  height: 18px;
  border-radius: 999px;
  background: #111827;
  color: #fff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
}

.cipher-map-value {
  min-width: 12px;
}

.piece {
  position: absolute;
  z-index: 5;
  transform: translate(-50%, -50%);
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 4px 8px 4px 4px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.94);
  border: 2px solid #111827;
  cursor: move;
  user-select: none;
  min-height: 42px;
}

.piece.selected {
  border-color: #2563eb;
  box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.18);
}

.piece-icon {
  width: 30px;
  height: 30px;
  object-fit: contain;
  border-radius: 6px;
  flex: 0 0 auto;
  pointer-events: none;
}

.piece-label {
  font-size: 12px;
  font-weight: 700;
  white-space: nowrap;
  color: #111827;
}

@media (max-width: 1100px) {
  .app {
    flex-direction: column;
    height: auto;
    min-height: 100vh;
    overflow: auto;
  }

  .sidebar {
    width: 100%;
    min-width: 0;
    max-width: none;
    border-right: 0;
    border-bottom: 1px solid #d1d5db;
  }

  .main {
    overflow: visible;
  }

  .board-wrap {
    min-height: auto;
  }

  .board {
    width: 100%;
  }

  .cipher-board-layer {
    grid-template-columns: repeat(3, auto);
  }
}